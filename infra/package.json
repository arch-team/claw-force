{
  "name": "infra",
  "version": "0.2.0",
  "bin": {
    "infra": "bin/infra.js"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "lint": "eslint 'lib/**/*.ts' 'bin/**/*.ts' 'test/**/*.ts'",
    "lint:fix": "eslint 'lib/**/*.ts' 'bin/**/*.ts' 'test/**/*.ts' --fix",
    "format:check": "prettier --check 'lib/**/*.ts' 'bin/**/*.ts' 'test/**/*.ts'",
    "format": "prettier --write 'lib/**/*.ts' 'bin/**/*.ts' 'test/**/*.ts'",
    "typecheck": "tsc --noEmit",
    "cdk": "cdk",
    "validate": "tsx scripts/validate-bedrock.ts"
  },
  "devDependencies": {
    "@aws-sdk/client-bedrock": "^3.1000.0",
    "@eslint/js": "^10.0.1",
    "@types/jest": "^30",
    "@types/node": "^24.10.1",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "aws-cdk": "^2.1108.0",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^30",
    "prettier": "^3.8.1",
    "ts-jest": "^29",
    "ts-node": "^10.9.2",
    "tslib": "^2.8.1",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "aws-cdk-lib": "^2.232.2",
    "cdk-nag": "^2.37.55",
    "constructs": "^10.0.0"
  }
}
