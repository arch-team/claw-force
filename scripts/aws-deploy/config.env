#!/usr/bin/env bash
# ============================================================================
# OpenClaw AWS EC2 PoC — 部署参数配置
# ============================================================================
# 使用方式: 被其他部署脚本 source 引入，请勿直接执行
# 安全提醒: 此文件不应包含任何密钥或敏感凭证
# ============================================================================

# ---------- AWS 基础配置 ----------
AWS_REGION="us-east-1"
AWS_PROFILE="${AWS_PROFILE:-default}"

# ---------- 命名前缀（便于识别和清理） ----------
PROJECT_PREFIX="openclaw-poc"

# ---------- IAM 配置 ----------
IAM_ROLE_NAME="${PROJECT_PREFIX}-role"
IAM_POLICY_NAME="${PROJECT_PREFIX}-bedrock-policy"
INSTANCE_PROFILE_NAME="${PROJECT_PREFIX}-instance-profile"

# ---------- EC2 配置 ----------
EC2_INSTANCE_TYPE="t3.medium"
EC2_VOLUME_SIZE=30                # GB, gp3
EC2_KEY_PAIR_NAME="${PROJECT_PREFIX}-key"
SECURITY_GROUP_NAME="${PROJECT_PREFIX}-sg"
INSTANCE_NAME="${PROJECT_PREFIX}-instance"

# ---------- 网络安全 ----------
# 留空则自动检测本机公网 IP（推荐）
# 设置为具体 CIDR 可限制访问来源，如 "203.0.113.10/32"
ALLOWED_SSH_CIDR="${ALLOWED_SSH_CIDR:-}"

# 是否限制 Gateway/Bridge 端口仅允许 ALLOWED_SSH_CIDR 访问
# "true" = 仅允许指定 IP（推荐），"false" = 允许所有 IP
RESTRICT_GATEWAY_ACCESS="${RESTRICT_GATEWAY_ACCESS:-true}"

# ---------- OpenClaw 配置 ----------
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_BRIDGE_PORT=18790

# Docker 构建选项: 设为 "1" 以安装浏览器自动化支持（+300MB）
INSTALL_BROWSER="${INSTALL_BROWSER:-1}"

# Node.js 内存限制（MB）
NODE_MAX_OLD_SPACE=2048

# ---------- Bedrock 配置 ----------
BEDROCK_REGION="${BEDROCK_REGION:-${AWS_REGION}}"
BEDROCK_DEFAULT_MODEL="anthropic.claude-3-5-sonnet-20241022-v2:0"

# ---------- 部署方式 ----------
# "rsync" = 同步本地 openclaw-fork 目录（开发迭代快）
# "git"   = 从远程仓库克隆（适合 CI/CD）
DEPLOY_METHOD="${DEPLOY_METHOD:-rsync}"
OPENCLAW_REPO_URL="${OPENCLAW_REPO_URL:-}"

# ---------- 生成文件路径（自动设置，无需修改） ----------
SSH_KEY_PATH="${HOME}/.ssh/${EC2_KEY_PAIR_NAME}"
EC2_INSTANCE_ID_FILE="/tmp/${PROJECT_PREFIX}-instance-id"
EC2_PUBLIC_IP_FILE="/tmp/${PROJECT_PREFIX}-public-ip"
